# Server
PORT=4001
NODE_ENV=development

# API Gateway Integration
# Shared secret for HMAC signature verification (same as gateway's GATEWAY_INTERNAL_SECRET)
# IMPORTANT: Generate with: openssl rand -hex 32
# CRITICAL: Use a strong random secret (32+ characters) for production
GATEWAY_INTERNAL_SECRET=generate_with_openssl_rand_hex_32

# MongoDB – separate DB for the file service
# For per-db mode use a placeholder: mongodb://localhost:27017/{tenant}_file_db
MONGO_URI=mongodb://localhost:27017/file_service_db

# docker-compose MongoDB auth (used by the mongo service)
MONGO_USER=fileadmin
MONGO_PASS=changeme

# Multi-tenancy mode: shared (single DB, tenantId field) | per-db (separate DB per tenant)
TENANCY_MODE=shared

# Enforce tenant scoping on every request.
# true  → resolve tenant from X-Tenant-Id (fallback DEFAULT_TENANT_ID=easydev).
# false → do not resolve/check tenant; ignore X-Tenant-Id even if provided.
TENANCY_ENABLED=true
# Default tenant ID used when X-Tenant-Id header is not provided.
# For single-tenant deployments set this to your slug. Leave blank to require the header explicitly.
DEFAULT_TENANT_ID=easydev

# Storage backend: local | s3 | gcs | azure | r2
STORAGE_TYPE=local

# Local storage
LOCAL_UPLOAD_DIR=uploads

# AWS S3 / Cloudflare R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# S3 Specific (used internally)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Google Cloud Storage
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_KEY_FILE=

# Azure Blob Storage
AZURE_CONNECTION_STRING=
AZURE_CONTAINER=

# Cloudflare R2
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET=
R2_BUCKET=
R2_PUBLIC_DOMAIN=

# File limits
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_RATE_LIMIT=10
UPLOAD_RATE_WINDOW=900000
SIGNED_URL_EXPIRY=3600

# CORS – allow main service origin
CORS_ORIGIN=http://localhost:3000

# ─── Scaling ──────────────────────────────────────────────────────────────────
# Number of Node.js cluster workers:
#   0 = auto (one worker per CPU core — recommended for production)
#   1 = single process, no clustering (default / development)
#   N = exactly N worker processes
CLUSTER_WORKERS=1

# Per-request server timeout in ms before the socket is forcibly closed (0 = disabled)
REQUEST_TIMEOUT_MS=30000

# General API rate limit — applied to ALL /api routes per IP address
# Default: 300 requests per 60 seconds
GENERAL_RATE_LIMIT=300
GENERAL_RATE_WINDOW=60000

# Enable gzip compression on HTTP responses (true | false)
ENABLE_COMPRESSION=true

# Redis — distributed rate limiting across cluster workers and container replicas
# Requires: npm install ioredis rate-limit-redis
# The docker-compose file derives REDIS_URL automatically from REDIS_PASSWORD.
# Set a strong random value here before deploying.
REDIS_PASSWORD=changeme_use_a_strong_secret
# Only set REDIS_URL manually when using an external Redis (e.g. Azure Cache for Redis):
# REDIS_URL=redis://:your_password@your-redis-host:6379
REQUEST_TIMEOUT_MS=30000