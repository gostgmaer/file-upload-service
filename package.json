{
  "name": "file-upload-service",
  "version": "1.0.0",
  "description": "Standalone file upload microservice with multi-tenant support",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "debug": "node --inspect=9231 server.js",
    "debug:dev": "nodemon --inspect=9231 server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest tests/integration",
    "install:deps": "pnpm install && pnpm add file-type@^19.0.0 express@^4.21.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.782.0",
    "@aws-sdk/s3-request-presigner": "^3.782.0",
    "@azure/storage-blob": "^12.26.0",
    "@google-cloud/storage": "^7.15.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.0",
    "joi": "^17.13.3",
    "mime": "^4.0.7",
    "mime-types": "^2.1.35",
    "mongoose": "^8.13.1",
    "multer": "^1.4.5-lts.2",
    "rate-limit-redis": "^4.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20"
  }
}
